{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "vercel dev",
  "installCommand": "pip install -r requirements.txt",
  "framework": null,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "outputDirectory": "frontend"

}